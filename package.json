{
  "name": "@toptensoftware/cantabile-js",
  "version": "0.3.4",
  "description": "",
  "main": "src/Cantabile.js",
  "type": "module",
  "types": "types.d.ts",
  "scripts": {
    "build": "rollup -c",
    "types": "(tsc --project tsconfig.emit.json) && (rm ./types/browser.*) && (dts flatten @toptensoftware/cantabile-js ./src/types.d.ts ./types/*.d.ts --out:types.d.ts) && (dts extract types.d.ts --out:types.d.json)",
    "docs": "(npm run types) && (rm -rf ./docs/API) && (node make-docs)",
    "serve-docs": "(npm run docs) && (doconly ./docs)",
    "build-docs": "(npm run docs) && (doconly ./docs --build --out:dist/docs)",
    "build-all": "(npm run build) && (npm run build-docs)",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "events": "^3.3.0",
    "isomorphic-fetch": "^3.0.0",
    "isomorphic-ws": "^4.0.1"
  },
  "devDependencies": {
    "@codeonlyjs/doconly": "github:codeonlyjs/doconly",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@rollup/plugin-replace": "^6.0.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-virtual": "^3.0.0",
    "@toptensoftware/dts": "github:toptensoftware/dts",
    "@toptensoftware/jsdoc": "github:toptensoftware/jsdoc",
    "@types/node": "^26.0.1",
    "@types/ws": "^8.18.1",
    "rollup": "^4.0.0",
    "rollup-plugin-polyfill-node": "^0.13.0",
    "typescript": "^6.0.3"
  }
}
